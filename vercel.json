{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "regions": ["hnd1"],
  "rewrites": [
    { "source": "/api/popular", "destination": "/api/index" },
    { "source": "/api/latest", "destination": "/api/index" },
    { "source": "/api/search", "destination": "/api/index" },
    { "source": "/api/novel/:ncode/chapters", "destination": "/api/index" },
    { "source": "/api/novel/:ncode/chapter/:num", "destination": "/api/index" },
    { "source": "/api/novel/:ncode", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
